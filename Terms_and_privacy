    <!-- Tab Switching Logic -->
    <script>
        function switchTab(tabId) {
            // Get DOM elements
            const contentTos = document.getElementById('content-tos');
            const contentPrivacy = document.getElementById('content-privacy');
            const btnTos = document.getElementById('btn-tos');
            const btnPrivacy = document.getElementById('btn-privacy');
            
            // Define styles for active and inactive states
            const activeClasses = ['bg-white/10', 'text-white', 'shadow-sm', 'border-white/5'];
            const inactiveClasses = ['text-slate-400', 'hover:bg-white/5', 'hover:text-slate-200', 'border-transparent'];
            
            // Reset both buttons
            btnTos.classList.remove(...activeClasses);
            btnTos.classList.add(...inactiveClasses);
            btnTos.querySelector('svg').classList.remove('opacity-70', 'translate-x-0');
            btnTos.querySelector('svg').classList.add('opacity-0', '-translate-x-2');
            
            btnPrivacy.classList.remove(...activeClasses);
            btnPrivacy.classList.add(...inactiveClasses);
            btnPrivacy.querySelector('svg').classList.remove('opacity-70', 'translate-x-0');
            btnPrivacy.querySelector('svg').classList.add('opacity-0', '-translate-x-2');

            // Hide both contents
            contentTos.classList.add('hidden');
            contentPrivacy.classList.add('hidden');

            // Activate selected tab
            if (tabId === 'tos') {
                contentTos.classList.remove('hidden');
                btnTos.classList.remove(...inactiveClasses);
                btnTos.classList.add(...activeClasses);
                btnTos.querySelector('svg').classList.remove('opacity-0', '-translate-x-2');
                btnTos.querySelector('svg').classList.add('opacity-70', 'translate-x-0');
            } else {
                contentPrivacy.classList.remove('hidden');
                btnPrivacy.classList.remove(...inactiveClasses);
                btnPrivacy.classList.add(...activeClasses);
                btnPrivacy.querySelector('svg').classList.remove('opacity-0', '-translate-x-2');
                btnPrivacy.querySelector('svg').classList.add('opacity-70', 'translate-x-0');
            }
            
            // Scroll to top on mobile when switching
            if(window.innerWidth < 768) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }
    </script>
</body>
</html>
